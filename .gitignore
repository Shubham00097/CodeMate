# ==========================================
# Common .gitignore for codeMate Workspace
# ==========================================

# 1. Dependency Directories (Recursive)
node_modules/
jspm_packages/
web_modules/

# Yarn specific
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# 2. Environment Secrets (Recursive - VERY IMPORTANT)
.env
.env.*
*.env
*.env.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# 3. Next.js / Frontend Builds & Cache
frontend/.next/
frontend/out/
frontend/coverage/

# 4. General Build/Distribution folders
build/
dist/
target/
out/
backend/build/
frontend/build/

# 5. OS Metadata & IDE config
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 6. Vercel / Deployments
.vercel

# 7. Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 8. Local SSL Certificates / PEM keys
*.pem
*.key
